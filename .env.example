# 환경변수 템플릿 — 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요.
#   Windows:  copy .env.example .env
#   (.env 는 gitignore 로 커밋되지 않습니다. 실제 키/시크릿은 .env 에만.)
#
# 저장소 루트에서 서비스를 실행할 때 CWD 기준으로 .env 를 읽습니다.

# === LLM 유닛 (services/llm-server) ===
# NVIDIA NIM API 키 — build.nvidia.com 에서 발급. 실키는 절대 커밋 금지. 이 유닛만 보유.
NVIDIA_API_KEY=

# (선택 — 기본값 있음, 바꿀 때만 주석 해제)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=openai/gpt-oss-120b


# === STT (services/orchestrator-server) — Azure Speech ===
# Azure Speech 키 — Portal "키 및 엔드포인트"에서 발급. 실키는 절대 커밋 금지.
# 리전은 한국(koreacentral) 고정 — PIPA 국외이전 회피(security.md).
AZURE_SPEECH_KEY=
# (선택 — 기본값 koreacentral, 바꿀 때만)
# AZURE_SPEECH_REGION=koreacentral